sub-TCGCore-check:
	@test -d TCGCore/ || mkdir -p TCGCore/
	cd TCGCore/ && ( test -e Makefile || $(QMAKE) -o Makefile /home/mpgasparini/Downloads/TCG-Nexus/TCGCore/TCGCore.pro -spec linux-g++ CONFIG+=debug CONFIG+=qml_debug ) && $(MAKE) -f Makefile check
