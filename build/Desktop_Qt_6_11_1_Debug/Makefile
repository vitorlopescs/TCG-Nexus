	cd TCGGUI/ && ( test -e Makefile || $(QMAKE) -o Makefile /home/mpgasparini/Downloads/TCG-Nexus/TCGGUI/TCGGUI.pro -spec linux-g++ CONFIG+=debug CONFIG+=qml_debug ) && $(MAKE) -f Makefile check
