TCGGUI.app/Contents/PkgInfo: 
	@test -d TCGGUI.app/Contents || mkdir -p TCGGUI.app/Contents
	@$(DEL_FILE) TCGGUI.app/Contents/PkgInfo
	@echo "APPL????" > TCGGUI.app/Contents/PkgInfo
TCGGUI.app/Contents/Info.plist: 
	@test -d TCGGUI.app/Contents || mkdir -p TCGGUI.app/Contents
	@$(DEL_FILE) TCGGUI.app/Contents/Info.plist
	@set -o pipefail && plutil -convert xml1 -o - /Users/bzn/Qt/6.11.1/macos/mkspecs/macx-clang/Info.plist.app | sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,com.yourcompany.TCGGUI,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},com.yourcompany.TCGGUI,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},13,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,\$${IOS_LAUNCH_SCREEN},LaunchScreen,g" -e "s,@ICON@,,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},,g" -e "s,@EXECUTABLE@,TCGGUI,g" -e "s,@LIBRARY@,TCGGUI,g" -e "s,\$${EXECUTABLE_NAME},TCGGUI,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" >TCGGUI.app/Contents/Info.plist

